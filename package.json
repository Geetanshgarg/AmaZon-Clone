{
  "name": "AmaZon-Clone",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @AmaZon-Clone/db db:push",
    "db:studio": "turbo -F @AmaZon-Clone/db db:studio",
    "db:generate": "turbo -F @AmaZon-Clone/db db:generate",
    "db:migrate": "turbo -F @AmaZon-Clone/db db:migrate"
  },
  "dependencies": {
    "@AmaZon-Clone/env": "*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@AmaZon-Clone/config": "*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "npm@11.10.1"
}
